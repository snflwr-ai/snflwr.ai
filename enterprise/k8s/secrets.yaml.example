# Kubernetes Secrets
# IMPORTANT: This file contains placeholder values
# In production, use: kubectl create secret generic snflwr-secrets --from-env-file=.env.production
# Or use a secret management solution like HashiCorp Vault, AWS Secrets Manager, etc.

apiVersion: v1
kind: Secret
metadata:
  name: snflwr-secrets
  namespace: snflwr-ai
type: Opaque
stringData:
  # JWT (Generate: python -c 'import secrets; print(secrets.token_hex(32))')
  JWT_SECRET_KEY: "CHANGE-THIS-TO-SECURE-RANDOM-64-CHAR-VALUE"

  # Encryption Key (Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())')
  ENCRYPTION_KEY: "CHANGE-THIS-TO-FERNET-KEY-44-CHARS"

  # PostgreSQL Password
  POSTGRES_PASSWORD: "CHANGE-THIS-SECURE-PASSWORD"

  # Redis Password
  REDIS_PASSWORD: "CHANGE-THIS-SECURE-PASSWORD"

  # SMTP Credentials
  SMTP_USERNAME: "apikey"
  SMTP_PASSWORD: "SG.CHANGE-THIS-SENDGRID-API-KEY"
  SMTP_FROM_EMAIL: "noreply@snflwr.ai"

  # Flower (Celery Monitoring UI)
  FLOWER_USER: "CHANGE-THIS-FLOWER-USERNAME"
  FLOWER_PASSWORD: "CHANGE-THIS-SECURE-PASSWORD"

  # Sentry DSN
  SENTRY_DSN: "https://examplePublicKey@o0.ingest.sentry.io/0"
