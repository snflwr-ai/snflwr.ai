# =============================================================================
# snflwr.ai — Production Environment Configuration
# =============================================================================
# Copy to .env.production and fill in real values.
# Or run: python scripts/setup_production.py (interactive, generates everything)
#
# IMPORTANT: Never commit real values to git. Keep this file secure (chmod 600).
# =============================================================================

# ---------------------------------------------------------------------------
# Environment (CRITICAL — triggers production security validation)
# ---------------------------------------------------------------------------
ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Security — Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE-THIS-generate-with-secrets-token-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Server-to-server auth key (Open WebUI → Snflwr API)
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
INTERNAL_API_KEY=CHANGE-THIS-generate-with-secrets-token-hex-32

# Parent dashboard password hash
# Generated automatically by setup_production.py
PARENT_DASHBOARD_PASSWORD=CHANGE-THIS-generate-with-secrets-token-hex-32

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_TYPE=postgresql
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=snflwr_db
POSTGRES_USER=snflwr
POSTGRES_PASSWORD=CHANGE-THIS-use-strong-password

# SSL mode for PostgreSQL connections (use 'require' or 'verify-full' in production)
POSTGRES_SSLMODE=require

# Database encryption (REQUIRED for FERPA compliance)
DB_ENCRYPTION_ENABLED=true
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
DB_ENCRYPTION_KEY=CHANGE-THIS-generate-with-secrets-token-urlsafe-32
DB_KDF_ITERATIONS=256000

# PII encryption (for parent email addresses)
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ENCRYPTION_KEY=CHANGE-THIS-generate-fernet-key

# ---------------------------------------------------------------------------
# Open WebUI
# ---------------------------------------------------------------------------
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
WEBUI_SECRET_KEY=CHANGE-THIS-generate-with-secrets-token-hex-32
ENABLE_SIGNUP=false

# ---------------------------------------------------------------------------
# Domain & URLs
# ---------------------------------------------------------------------------
DOMAIN=snflwr.example.com
BASE_URL=https://snflwr.example.com
FRONTEND_URL=https://snflwr.example.com
API_URL=https://snflwr.example.com/api/snflwr
CORS_ORIGINS=https://snflwr.example.com

# ---------------------------------------------------------------------------
# Redis (REQUIRED for production — rate limiting, session distribution)
# ---------------------------------------------------------------------------
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE-THIS-if-redis-requires-auth
REDIS_DB=0

# ---------------------------------------------------------------------------
# Celery (background tasks — backup, data retention, email alerts)
# ---------------------------------------------------------------------------
CELERY_ENABLED=true
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKERS=4
CELERY_LOG_LEVEL=INFO

# Flower monitoring UI (optional)
FLOWER_ENABLED=false
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE-THIS-to-secure-password

# ---------------------------------------------------------------------------
# Email (SMTP — for parent safety alerts, COPPA compliance)
# ---------------------------------------------------------------------------
SMTP_ENABLED=true
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=CHANGE-THIS-to-sendgrid-api-key
SMTP_FROM_EMAIL=alerts@snflwr.example.com
SMTP_FROM_NAME=snflwr.ai Safety Monitor
SMTP_USE_TLS=true
ADMIN_EMAIL=admin@snflwr.example.com

# ---------------------------------------------------------------------------
# AI Model
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
# User-facing chat model — built by docker/Dockerfile.ollama as a wrapper
# around CHAT_MODEL below. Always 'snflwr.ai'.
OLLAMA_DEFAULT_MODEL=snflwr.ai

# Docker Compose: model build args (used by Dockerfile.ollama)
# CHAT_MODEL is the BASE qwen3.5 model that snflwr.ai is built on top of.
# Choose based on server RAM (see docker/Dockerfile.ollama for sizing).
CHAT_MODEL=qwen3.5:9b
SAFETY_MODEL=llama-guard3:1b

# ---------------------------------------------------------------------------
# Safety (always enabled in production — cannot be disabled)
# ---------------------------------------------------------------------------
SAFETY_PIPELINE_ENABLED=true
ENABLE_SAFETY_MONITORING=true
ENABLE_SAFETY_MODEL=true
ALERT_THRESHOLD_MINOR=5
ALERT_THRESHOLD_MAJOR=2
SAFETY_LOG_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=365
SESSION_RETENTION_DAYS=180

# Feature flags
FREEMIUM_ENABLED=true
PARENT_DASHBOARD_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=true

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false
LOG_LEVEL=INFO
STARTUP_TIMEOUT_SECONDS=60
MAX_REQUEST_SIZE_MB=10
# Must exceed OLLAMA_TIMEOUT (default 300) to avoid premature request cancellation
REQUEST_TIMEOUT_SECONDS=360
# Disable docs UI in production
ENABLE_API_DOCS=false
# Enable HSTS for HTTPS deployments
ENABLE_HSTS=true
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
PROMETHEUS_METRICS_TOKEN=CHANGE-THIS-to-random-token

# CSRF cookie must be sent only over HTTPS
CSRF_COOKIE_SECURE=true

# ---------------------------------------------------------------------------
# Monitoring (optional but recommended)
# ---------------------------------------------------------------------------
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Plugins (SECURITY WARNING: keep FALSE for K-12 COPPA deployments)
ENABLE_PLUGINS=false
