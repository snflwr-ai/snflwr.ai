# snflwr.ai - Docker Compose Environment
# ============================================
# Copy to .env and fill in values before running:
#   cp .env.example .env
#   docker compose up -d
#
# Or use the setup script to generate everything:
#   python ../../scripts/setup_production.py

# ── Required secrets (generate before first run) ──────────────────────
# python -c 'import secrets; print(secrets.token_hex(32))'
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=require
REDIS_PASSWORD=
JWT_SECRET_KEY=
INTERNAL_API_KEY=
WEBUI_SECRET_KEY=

# ── AI models (required) ─────────────────────────────────────────────
# Backbone model snflwr.ai is built on (gemma4:e4b is the recommended default —
# won the 2026-06-17 tutoring-quality bake-off; see evals/tutoring/backbone_bakeoff.py).
# Boxes under ~16 GB can fall back to a small qwen3.5 tier (qwen3.5:4b / :2b / :0.8b).
CHAT_MODEL=gemma4:e4b
# Safety classifier (mandatory for K-12)
SAFETY_MODEL=llama-guard3:1b

# ── Optional ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_SIGNUP=false

# CORS (set to your domain in production)
CORS_ORIGINS=https://localhost

# Email notifications (for parent safety alerts)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
ADMIN_EMAIL=
