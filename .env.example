# snflwr.ai - Environment Configuration Example
# ================================================
# Copy this file to .env and fill in your actual values.
# For production, you can also use .env.production (takes priority over .env).
# This file is safe to commit (contains no real credentials)

# Environment
ENVIRONMENT=development  # Options: development, staging, production

# Database
DB_TYPE=sqlite  # Options: sqlite, postgresql

# PostgreSQL (only needed if DB_TYPE=postgresql)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=snflwr_db
POSTGRES_USER=snflwr
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=prefer  # Production: use 'require' or 'verify-full'

# Database Encryption (SQLite only - AES-256 encryption at rest)
# IMPORTANT: Keep encryption key secure! Never commit to version control.
# Generate strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_ENCRYPTION_ENABLED=false  # Set to 'true' to enable encryption at rest
DB_ENCRYPTION_KEY=  # 32+ character encryption key (required if encryption enabled)
DB_KDF_ITERATIONS=256000  # PBKDF2 iterations (higher = more secure, slower)

# JWT Authentication
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET_KEY=change-this-to-secure-random-value-64-characters-minimum
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Server
API_HOST=0.0.0.0
API_PORT=39150
API_WORKERS=4
API_RELOAD=false
LOG_LEVEL=INFO
# Maximum seconds to wait for startup before aborting (default: 60)
STARTUP_TIMEOUT_SECONDS=60
# Maximum HTTP request body size in megabytes (default: 10)
MAX_REQUEST_SIZE_MB=10
# Maximum seconds for a single HTTP request (must exceed OLLAMA_TIMEOUT; default: 360)
REQUEST_TIMEOUT_SECONDS=360
# Enable OpenAPI /docs and /redoc endpoints — disable in production
ENABLE_API_DOCS=true
# Enable HTTP Strict Transport Security header — enable in production with HTTPS
ENABLE_HSTS=false
# Bearer token for /api/metrics — leave empty to disable the metrics endpoint
PROMETHEUS_METRICS_TOKEN=

# CORS
CORS_ORIGINS=https://yourdomain.com

# Email Notifications (SMTP)
SMTP_ENABLED=true
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG.your_sendgrid_api_key_here
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=snflwr.ai Safety Monitor
SMTP_USE_TLS=true

# Admin Email (for critical alerts like audit log failures)
# REQUIRED for COPPA/FERPA compliance alerting
ADMIN_EMAIL=admin@yourdomain.com

# Encryption
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ENCRYPTION_KEY=change-this-to-fernet-key-44-characters
ENCRYPT_CONVERSATIONS=true  # COPPA/FERPA: encrypt student conversations at rest

# CSRF Protection
CSRF_ENABLED=true
CSRF_SECRET=  # Leave blank to auto-derive from JWT_SECRET_KEY
CSRF_COOKIE_SECURE=false  # Set true in production (requires HTTPS)
CSRF_COOKIE_SAMESITE=strict

# Internal API Key (server-to-server auth between Open WebUI and Snflwr API)
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
INTERNAL_API_KEY=snflwr-internal-dev-key

# Open WebUI
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
WEBUI_SECRET_KEY=change-this-to-secure-random-value
ENABLE_SIGNUP=false  # Set true temporarily to allow initial user registration

# Application URLs
BASE_URL=http://localhost:39150
OPEN_WEBUI_URL=http://localhost:3000

# Parent Dashboard
PARENT_DASHBOARD_PASSWORD=  # Required for parent dashboard access

# Safety Monitoring
ENABLE_SAFETY_MONITORING=true
ALERT_THRESHOLD_MINOR=5
ALERT_THRESHOLD_MAJOR=2
SAFETY_LOG_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=365
SESSION_RETENTION_DAYS=180

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW=60
RATE_LIMIT_API_MAX=1000
RATE_LIMIT_API_WINDOW=60

# SSL/TLS
SSL_ENABLED=false

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/var/backups/snflwr_ai

# Ollama (AI inference)
OLLAMA_BASE_URL=http://localhost:11434
# Ollama request timeout in seconds. Increase for large models or long responses (thinking models need 2-5 min).
OLLAMA_TIMEOUT=300
# User-facing chat model — what kids see in the Open WebUI dropdown.
# Always 'snflwr.ai'. Built locally by the install/deploy scripts as a wrapper
# around the CHAT_MODEL base below using models/Snflwr_AI_Kids.modelfile.
OLLAMA_DEFAULT_MODEL=snflwr.ai

# Docker Compose: model build args (only needed for docker/compose deployment)
# CHAT_MODEL selects the base LLM that snflwr.ai is built on top of —
# choose based on available RAM:
#   qwen3.5:0.8b (2 GB+), qwen3.5:2b (4 GB+), qwen3.5:4b (6 GB+),
#   qwen3.5:9b (8 GB+, recommended), qwen3.5:27b (24 GB+), qwen3.5:35b (32 GB+)
CHAT_MODEL=qwen3.5:9b
SAFETY_MODEL=llama-guard3:1b

# Redis (Required for production - caching, rate limiting, Celery)
# Default false for development; set true for production
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis Sentinel (High Availability - Optional but recommended for production)
# When enabled, provides automatic failover if Redis master fails
# Use with docker-compose.redis-sentinel.yml
REDIS_SENTINEL_ENABLED=false
# Comma-separated list of sentinel nodes (host:port)
REDIS_SENTINEL_HOSTS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# Master name (must match sentinel configuration)
REDIS_SENTINEL_MASTER=mymaster

# Celery (Background Task Queue)
CELERY_ENABLED=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKERS=4
CELERY_LOG_LEVEL=INFO

# Flower (Celery Monitoring UI)
FLOWER_ENABLED=false
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=change-this-to-secure-password

# Sentry (Error Tracking & Performance Monitoring)
SENTRY_ENABLED=false
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_IN_DEV=false

# Plugins (SECURITY WARNING)
# Plugins use exec() which allows arbitrary code execution
# Only enable if you trust all plugin sources
# For K-12 COPPA-compliant deployments, keep this FALSE
ENABLE_PLUGINS=false

# ── Deployment Mode ────────────────────────────────────
# Controls how the launcher discovers its configuration and data.
# Options: auto, usb, local, thin_client
#   auto         - Try USB first, fall back to local (default)
#   usb          - Require a snflwr.ai USB device
#   local        - Use the local data directory (no USB required)
#   thin_client  - Connect to a management server for config & updates
# SNFLWR_DEPLOY_MODE=auto

# Management server URL (required for thin_client mode)
# The central server that pushes configuration and updates to thin clients.
# MANAGEMENT_SERVER_URL=https://school-server.local:39150
