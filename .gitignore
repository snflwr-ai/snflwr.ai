# Secrets — never commit. Ignore ALL real env files (incl. .env.production, which
# setup_production.py writes live secrets into); keep only the *.example templates.
.env
.env.*
!.env.example
!.env.*.example
CREDENTIALS.md

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
*.egg-info/
dist/
.pytest_cache/
.mypy_cache/

# Logs & runtime data
logs/
*.log
*.db
*.sqlite

# OS
.DS_Store
Thumbs.db

# Node
node_modules/

# Built frontend (regenerate with scripts/build-frontend.sh)
frontend/open-webui/build/

# IDE
.idea/
.vscode/
*.swp

# Generated data dirs
data/
storage/data/
*.bak

# Runtime audit logs (generated by key_management.py)
config/audit/

# Test coverage reports
.coverage

# Generated tutoring-eval outputs (evals/tutoring/*.py write these to the repo
# root). The scorers/harness are tracked; the run artifacts are not.
/tutoring_eval_report.*
/tutoring_bakeoff_report.*
/backbone_bakeoff_report.*
/tuning_check_report.*

# SSL certificates and private keys
*.key
*.pem
*.crt
*.cert
# ...except the bundled license PUBLIC key (not a secret; must ship with the app
# for offline token verification). The signing PRIVATE key never lives here.
!config/license_public_key.pem
*.p12
*.pfx

# Generated credentials file — never commit
CREDENTIALS.md
CREDENTIALS*.md

# Local Claude Code permission allowlist (not for the public repo)
.claude/settings.json

# Local Claude Code working-instructions file (not application docs — keep local)
CLAUDE.md

# Local bake-off judge-path artifacts (process output, not app docs)
judge_tasks.jsonl
judge_verdicts.json
judge_rerun_report.md
judge_rerun_report.json

# Legal documents are kept LOCAL ONLY (DRAFT / not in effect / pre-counsel-review).
# The whole legal/ tree stays out of the public repo until finalized.
legal/
